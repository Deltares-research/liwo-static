{
  "name": "liwo-static",
  "version": "3.32.0",
  "private": true,
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest --dom",
    "test:e2e": "cypress run",
    "test:long-running": "E2E_MODE=long-running vue-cli-service test:e2e",
    "lint": "eslint . --fix --ignore-pattern .gitignore --ignore-pattern dist",
    "docker": "docker run --rm -p8080:80 --name liwo-static -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf:ro -v $(pwd)/dist:/usr/share/nginx/html nginx",
    "release": "semantic-release"
  },
  "dependencies": {
    "@piwikpro/vue-piwik-pro": "^1.7.0",
    "@semantic-release/git": "^10.0.1",
    "@vue-a11y/skip-to": "^3.0.3",
    "dom-to-image": "^2.6.0",
    "driver.js": "^1.4.0",
    "fast-equals": "^6.0.0",
    "file-saver": "^2.0.5",
    "focus-trap": "^8.2.1",
    "leaflet": "^1.9.4",
    "leaflet-control-geocoder": "^3.3.1",
    "leaflet-easyprint": "^2.1.9",
    "leaflet.browser.print": "^2.0.2",
    "leaflet.markercluster": "^1.5.3",
    "lodash": "^4.18.1",
    "portal-vue": "^3.0.0",
    "proj4leaflet": "^1.0.2",
    "query-string": "^9.4.0",
    "sanitize-html": "^2.17.5",
    "tiny-cookie": "^2.5.1",
    "vue": "^3.5.25",
    "vue-cookie-law": "^1.13.3",
    "vue-router": "^5.1.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@cypress/skip-test": "^2.6.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "chai-things": "^0.2.0",
    "cypress": "^15.17.0",
    "eslint": "^9.39.1",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "imports-loader": "^5.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "postcss-import": "^16.1.1",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "semantic-release": "^25.0.5",
    "vite": "^7.3.2",
    "vitest": "^4.0.15"
  }
}
